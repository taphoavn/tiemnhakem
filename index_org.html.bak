<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <title>Tiệm Tạp Hóa Nhà Kem | Văn phòng phẩm & Phụ kiện xinh xắn</title>
    <meta name="description" content="Khám phá góc nhỏ của Tiệm tạp hóa nhà Kem với vô vàn sticker, sổ tay, bút viết và phụ kiện dễ thương. Mua sắm ngay những món đồ cực xinh có trong video!">
    <meta name="keywords" content="văn phòng phẩm, sticker, sổ tay, bút cute, phụ kiện dễ thương, tiệm tạp hóa nhà kem, đồ dùng học tập">
    <meta name="author" content="Tiệm tạp hóa nhà Kem">
    
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://taphoanhakem.com/"> <meta property="og:title" content="Tiệm Tạp Hóa Nhà Kem | Đồ xinh cho bạn">
    <meta property="og:description" content="Khám phá góc nhỏ của Tiệm tạp hóa nhà Kem với vô vàn đồ dùng học tập, sticker và phụ kiện dễ thương.">
    <meta property="og:image" content="./assets/logo.jpg">

    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/vue@2/dist/vue.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Store",
      "name": "Tiệm tạp hóa nhà Kem",
      "image": "./assets/logo.jpg",
      "description": "Cửa hàng chuyên cung cấp văn phòng phẩm, đồ dùng học tập, sticker , hình dán công chúa và phụ kiện dễ thương.",
      "url": "https://taphoanhakem.com",
      "sameAs": [
        "https://www.facebook.com/taphoacutee",
        "https://www.instagram.com/tiemtaphoanhakem",
        "https://www.youtube.com/@tiemtaphoanhakem",
        "https://www.tiktok.com/@tiemtaphoanhakem_01"
      ]
    }
    </script>
</head>

<body class="bg-[#fcf9f2] text-gray-800 antialiased min-h-screen flex justify-center items-start sm:py-8">
    <main id="app" class="relative w-full max-w-md mx-auto p-5 sm:p-6 bg-white/80 backdrop-blur-md shadow-xl rounded-2xl border border-red-50">
        
        <header class="flex flex-col items-center mb-6 text-center">
            <div class="relative mb-3">
                <img :src="imgLogo" alt="Tiệm tạp hóa nhà Kem Logo" class="rounded-full w-28 h-28 object-cover shadow-md border-4 border-white">
                <span class="absolute bottom-1 right-1 bg-green-400 w-4 h-4 rounded-full border-2 border-white" title="Đang hoạt động"></span>
            </div>
            
            <h1 class="text-2xl font-bold text-gray-900 mb-1">{{ shopName }}</h1>
            
            <div class="flex items-center gap-1 text-sm text-gray-500 hover:text-pink-500 transition-colors mb-3">
                <span>IG:</span>
                <a :href="'https://www.instagram.com/' + instagram" target="_blank" rel="noopener noreferrer" class="font-medium flex items-center gap-1">
                    {{ instagram }}
                    <svg class="w-4 h-4 animate-bounce-horizontal" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                </a>
            </div>
            
            <nav aria-label="Social Links" class="flex gap-4 mb-3">
                <a href="https://www.instagram.com/tiemtaphoanhakem" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="transform hover:scale-110 transition-transform">
                    <i class="fab fa-instagram text-transparent bg-clip-text bg-gradient-to-tr from-yellow-400 via-pink-500 to-purple-500 text-3xl"></i>
                </a>
                <a href="https://www.facebook.com/taphoacutee" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="transform hover:scale-110 transition-transform">
                    <i class="fab fa-facebook text-blue-600 text-3xl"></i>
                </a>
                <a href="https://www.youtube.com/@tiemtaphoanhakem" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="transform hover:scale-110 transition-transform">
                    <i class="fab fa-youtube text-red-600 text-3xl"></i>
                </a>
                <a href="https://www.tiktok.com/@tiemtaphoanhakem_01" target="_blank" rel="noopener noreferrer" aria-label="TikTok" class="transform hover:scale-110 transition-transform">
                    <i class="fab fa-tiktok text-black text-3xl"></i>
                </a>
            </nav>
            
            <p class="text-sm font-medium text-gray-600 bg-red-50 py-2 px-4 rounded-full inline-block">{{ description }}</p>
        </header>

        <section aria-labelledby="products-heading">
            <h2 id="products-heading" class="text-lg font-bold text-gray-800 mb-3 flex items-center gap-2">
                Đồ của Kemm trong các video <span class="text-xl">🛒</span>
            </h2>
            
            <nav aria-label="Product Categories" class="flex flex-wrap gap-2 mb-4">
                <button v-for="(item, itemIndex) in listTab" :key="itemIndex"
                    @click="changeTabActive(item.id)"
                    class="py-1.5 px-3 text-xs font-semibold rounded-full border transition-all duration-200"
                    :class="item.id == tabActive ? 'bg-red-400 text-white border-red-400 shadow-md' : 'bg-white text-gray-600 border-gray-200 hover:border-red-300 hover:text-red-400'">
                    {{item.name}}
                </button>
                <button @click="productsRender = productsOrigin; tabActive = ''"
                    class="py-1.5 px-3 text-xs font-semibold rounded-full border bg-gray-50 text-gray-500 border-gray-200 hover:bg-gray-100 transition-all duration-200">
                    <i class="fas fa-undo mr-1"></i> Tất cả
                </button>
            </nav>
            
            <div class="grid grid-cols-2 gap-3 sm:gap-4">
                <article v-for="(product, index) in productsRender" :key="index"
                    class="group bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-lg border border-red-50 transition-all duration-300 flex flex-col">
                    
                    <div class="relative overflow-hidden aspect-square cursor-pointer" @click="redirectToSP(product.link)">
                        <img :src="product.image" :alt="product.description" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                    </div>
                    
                    <div class="p-3 flex flex-col flex-grow">
                        <h3 class="text-sm font-bold text-gray-800 line-clamp-2 mb-2 flex-grow" :title="product.description">{{ product.description }}</h3>
                        
                        <div class="flex gap-2 justify-between mt-auto">
                            <button @click="redirectToSP(product.link)" class="flex-1 text-xs font-bold text-white bg-red-400 rounded-lg py-1.5 hover:bg-red-500 transition-colors shadow-sm">
                                Mua ngay
                            </button>
                            <button @click="showImgs(product)" class="flex-1 text-xs font-bold text-orange-500 bg-orange-50 border border-orange-200 rounded-lg py-1.5 hover:bg-orange-100 transition-colors">
                                Xem ảnh
                            </button>
                        </div>
                    </div>
                </article>
            </div>
        </section>

        <div v-if="listImgRender.length" class="fixed inset-0 z-50 h-screen flex items-center justify-center">
            <div @click="listImgRender = []; indexShow = 0" class="absolute inset-0 bg-black/80 backdrop-blur-sm transition-opacity"></div>
            
            <div class="relative z-10 w-full max-w-lg px-4 flex flex-col items-center">
                <button @click="listImgRender = []; indexShow = 0" class="absolute -top-10 right-4 text-white hover:text-red-400 transition-colors">
                    <i class="fas fa-times text-3xl"></i>
                </button>
                
                <div class="flex items-center justify-between w-full">
                    <button @click="prevImg()" class="p-2 text-white hover:text-red-400 hover:scale-110 transition-all focus:outline-none">
                        <i class="fas fa-chevron-left text-4xl drop-shadow-lg"></i>
                    </button>
                    
                    <img :src="listImgRender[indexShow]" alt="Product Gallery" class="w-64 h-64 sm:w-80 sm:h-80 object-cover rounded-xl shadow-2xl select-none animate-fade-in">
                    
                    <button @click="nextImg()" class="p-2 text-white hover:text-red-400 hover:scale-110 transition-all focus:outline-none">
                        <i class="fas fa-chevron-right text-4xl drop-shadow-lg"></i>
                    </button>
                </div>
                
                <div class="mt-4 px-3 py-1 bg-black/50 text-white text-sm rounded-full">
                    {{ indexShow + 1 }} / {{ listImgRender.length }}
                </div>
            </div>
        </div>

    </main>

    <script>
        // Data gốc giữ nguyên
        const TYPE_PRODUCT = { STICKER: 1, BOOK: 2, PEN: 3, LIGHT: 4, ACCESSORY: 5 };
        const products = [
            { link: 'https://s.shopee.vn/30U1bsICYn', image: './assets/so1.jpg', description: 'Sổ sticker', arrayImage: ['./assets/so1.jpg', './assets/so2.jpg', './assets/so3.jpg', './assets/so4.jpg', './assets/so5.jpg', './assets/so6.jpg', './assets/so7.jpg', './assets/so8.jpg'], type: TYPE_PRODUCT.STICKER },
            { link: 'https://vn.shp.ee/tTtJoaT', image: './assets/den1.jpg', description: 'Đèn cute để bàn', arrayImage: ['./assets/den1.jpg', './assets/den2.jpg', './assets/den3.jpg', './assets/den4.jpg', './assets/den5.jpg'], type: TYPE_PRODUCT.LIGHT },
            { link: 'https://s.shopee.vn/AUa2XnhcB0', image: './assets/compo2.jpg', description: 'Combo học tập', arrayImage: ['./assets/compo1.jpg', './assets/compo2.jpg', './assets/compo3.jpg', './assets/compo4.jpg'], type: TYPE_PRODUCT.BOOK },
            { link: 'https://s.shopee.vn/3q38bVz4TG', image: './assets/but101.jpg', description: 'Bút 10 màu cutee', arrayImage: ['./assets/but101.jpg', './assets/but102.jpg', './assets/but103.jpg'], type: TYPE_PRODUCT.PEN },
            { link: 'https://s.shopee.vn/4VIpOavpzu', image: './assets/hop1.jpg', description: 'Hộp sticker 200 tấm', arrayImage: ['./assets/hop1.jpg', './assets/hop2.jpg', './assets/hop3.jpg', './assets/hop4.jpg', './assets/hop5.jpg', './assets/hop6.jpg'], type: TYPE_PRODUCT.STICKER },
            { link: 'https://s.shopee.vn/7Kd0m1ABZX', image: './assets/book1.jpg', description: 'Vở cute', arrayImage: ['./assets/book1.jpg', './assets/book2.jpg', './assets/book3.jpg', './assets/book4.jpg', './assets/book5.jpg', './assets/book6.jpg'], type: TYPE_PRODUCT.BOOK },
            { link: 'https://s.shopee.vn/7Kd0m1ABZX', image: './assets/tay1.jpg', description: 'Tẩy chì nèe', arrayImage: ['./assets/tay1.jpg', './assets/tay2.jpg', './assets/tay3.jpg', './assets/tay4.jpg'], type: TYPE_PRODUCT.ACCESSORY },
            { link: 'https://s.shopee.vn/9pKPyGPPVZ', image: './assets/note1.jpg', description: 'Giấy note cute', arrayImage: ['./assets/note1.jpg', './assets/note2.jpg', './assets/note3.jpg', './assets/note4.jpg', './assets/note5.jpg', './assets/note6.jpg'], type: TYPE_PRODUCT.ACCESSORY },
            { link: 'https://s.shopee.vn/2LEP2W4d2A', image: './assets/guong1.jpg', description: 'Gương mini', arrayImage: ['./assets/guong1.jpg', './assets/guong2.jpg', './assets/guong3.jpg', './assets/guong4.jpg', './assets/guong5.jpg'], type: TYPE_PRODUCT.ACCESSORY },
            { link: 'https://vn.shp.ee/XKhwxKK', image: './assets/cuon3.jpg', description: 'Cuộn sticker', arrayImage: ['./assets/cuon1.jpg', './assets/cuon2.jpg', './assets/cuon3.jpg', './assets/cuon4.jpg', './assets/cuon5.jpg', './assets/cuon6.jpg'], type: TYPE_PRODUCT.STICKER },
        ];

        document.addEventListener('DOMContentLoaded', function () {
            new Vue({
                el: '#app',
                data: {
                    shopName: 'Tiệm tạp hóa nhà Kem',
                    instagram: 'tiemtaphoanhakem',
                    tiktokId: '@tiemtaphoanhakem_01',
                    description: 'Cảm ơn bạn đã ghé nhaaa <3', // Giữ trống slogan theo nguyên tắc của bạn
                    imgLogo: './assets/logo.jpg',
                    listTab: [
                        { id: 1, name: 'Sticker' },
                        { id: 2, name: 'Vở' },
                        { id: 3, name: 'Bút' },
                        { id: 4, name: 'Đèn' },
                        { id: 5, name: 'Phụ kiện' },
                    ],
                    tabActive: '',
                    productsOrigin: products,
                    productsRender: products,
                    listImgRender: [],
                    indexShow: 0,
                },
                mounted() {
                    this.logTelegram();
                },
                methods: {
                    detectDevice() {
                        try {
                            let userAgent = window.navigator.userAgent, platform = window.navigator.platform,
                                macosPlatforms = ['Macintosh', 'MacIntel', 'MacPPC', 'Mac68K'],
                                windowsPlatforms = ['Win32', 'Win64', 'Windows', 'WinCE'],
                                iosPlatforms = ['iPhone', 'iPad', 'iPod'], os = null;

                            if (macosPlatforms.indexOf(platform) !== -1) { os = 'Mac OS'; } 
                            else if (iosPlatforms.indexOf(platform) !== -1) { os = 'iOS'; } 
                            else if (windowsPlatforms.indexOf(platform) !== -1) { os = 'Windows'; } 
                            else if (/Android/.test(userAgent)) { os = 'Android'; } 
                            else if (!os && /Linux/.test(platform)) { os = 'Linux'; }
                            return os || 'Unknown';
                        } catch (error) { return 'Lỗi check thiết bị'; }
                    },
                    logTelegram() {
                        // CẢNH BÁO: Việc để bot token lộ ở client side JS sẽ có rủi ro bảo mật.
                        // Nếu dự án lớn mạnh hơn, bạn nên chuyển phần này qua 1 API trung gian ở Backend.
                        let date = new Date();
                        const dateformat = `${date.getFullYear()}-${(date.getMonth() + 1).toString().padStart(2, '0')}-${date.getDate().toString().padStart(2, '0')} ${date.getHours().toString().padStart(2, '0')}:${date.getMinutes().toString().padStart(2, '0')}:${date.getSeconds().toString().padStart(2, '0')}`;
                        const botToken = '7494446429:AAEwoKyWgUeIb9FX0baCcffJELc0_E3lZVA';
                        const chatId = '-1002187943904';
                        const message = `🔔 Truy cập Tiệm nhà Kem từ: ${this.detectDevice()}\n⏰ Lúc: ${dateformat}`;

                        const url = `https://api.telegram.org/bot${botToken}/sendMessage`;
                        axios.post(url, { chat_id: chatId, text: message })
                            .catch(error => console.error('Error logging:', error));
                    },
                    showImgs(product) {
                        this.listImgRender = product.arrayImage ?? [];
                        this.indexShow = 0;
                    },
                    nextImg() {
                        this.indexShow = (this.indexShow < this.listImgRender.length - 1) ? this.indexShow + 1 : 0;
                    },
                    prevImg() {
                        this.indexShow = (this.indexShow > 0) ? this.indexShow - 1 : this.listImgRender.length - 1;
                    },
                    changeTabActive(value) {
                        this.tabActive = value;
                        this.productsRender = products.filter(item => item.type == value) ?? [];
                    },
                    redirectToSP(link) {
                        window.open(link, '_blank', 'noopener,noreferrer');
                    },
                },
            });
        }, false);
    </script>

    <style>
        /* CSS tuỳ chỉnh bổ sung cho các class Tailwind chưa có sẵn hiệu ứng */
        html, body {
            font-family: "Quicksand", sans-serif;
            background-image: radial-gradient(#ffcdd2 1px, transparent 1px);
            background-size: 20px 20px; /* Thêm họa tiết chấm bi chìm cực dễ thương cho background */
        }

        .animate-bounce-horizontal {
            animation: bounce-horizontal 1s infinite alternate ease-in-out;
        }

        @keyframes bounce-horizontal {
            from { transform: translateX(-3px); }
            to { transform: translateX(3px); }
        }

        .animate-fade-in {
            animation: fadeIn 0.3s ease-in-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: scale(0.95); }
            to { opacity: 1; transform: scale(1); }
        }
    </style>
</body>
</html>